<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>To My Love ❤️</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:linear-gradient(135deg,#ff9ecf,#ffe6f2);
    overflow-x:hidden;
    text-align:center;
    color:#fff;
}

.container{
    max-width:700px;
    margin:80px auto;
    padding:40px;
    background:rgba(255,255,255,.18);
    backdrop-filter:blur(12px);
    border-radius:25px;
    box-shadow:0 10px 30px rgba(0,0,0,.2);
}

h1{
    font-size:3rem;
}

.subtitle{
    margin:15px 0 30px;
    font-size:1.2rem;
}

.heart{
    font-size:70px;
    animation:beat 1s infinite;
}

@keyframes beat{
    0%,100%{transform:scale(1);}
    50%{transform:scale(1.2);}
}

p{
    line-height:1.8;
    font-size:18px;
}

button{
    margin-top:30px;
    padding:15px 35px;
    border:none;
    border-radius:40px;
    background:#ff4d88;
    color:white;
    font-size:18px;
    cursor:pointer;
    transition:.3s;
}

button:hover{
    transform:scale(1.08);
    background:#ff2f73;
}

#surprise{
    display:none;
    margin-top:30px;
    font-size:22px;
    animation:fade 1s;
}

@keyframes fade{
    from{opacity:0;}
    to{opacity:1;}
}

.floating-heart{
    position:fixed;
    color:white;
    animation:float 8s linear infinite;
    opacity:.7;
    pointer-events:none;
}

@keyframes float{
    from{
        transform:translateY(100vh);
        opacity:0;
    }
    20%{
        opacity:1;
    }
    to{
        transform:translateY(-100vh);
        opacity:0;
    }
}
</style>

</head>
<body>

<div class="container">

<div class="heart">❤️</div>

<h1>To My Favorite Person</h1>

<div class="subtitle">
You are my safest place, my biggest smile, and my happiest thought.
</div>

<p>
Every day with you feels like a beautiful blessing.
Thank you for loving me, supporting me, and making my world brighter.
No matter what happens, I'll always choose you.
</p>

<button onclick="showLove()">
Click Me ❤️
</button>

<div id="surprise">
💖 I love you more than words can ever explain.<br><br>
Forever & Always ❤️
</div>

</div>

<script>
function showLove(){
document.getElementById("surprise").style.display="block";
}

function createHeart(){
const heart=document.createElement("div");
heart.classList.add("floating-heart");
heart.innerHTML=["❤️","💖","💕","💗","💘"][Math.floor(Math.random()*5)];
heart.style.left=Math.random()*100+"vw";
heart.style.fontSize=(20+Math.random()*30)+"px";
heart.style.animationDuration=(5+Math.random()*5)+"s";
document.body.appendChild(heart);

setTimeout(()=>{
heart.remove();
},10000);
}

setInterval(createHeart,350);
</script>

</body>
</html>
